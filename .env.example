# データベースURL (SQLite)
DATABASE_URL="file:./dev.db"

# キャプション生成にClaude APIを使う場合 (任意)
# ANTHROPIC_API_KEY="sk-ant-..."

# ─── X (Twitter) API ─────────────────────────────────────────────────────────
# Developer Portal: https://developer.twitter.com/en/portal/dashboard
#
# 【画像取得（一括解析CSV）に使う認証】
#   方法 1（推奨・簡単）: X_BEARER_TOKEN のみ設定
#     → Developer Portal の 'Keys and Tokens' > 'Bearer Token' からコピー
#     → 投稿機能は使えない（読み取り専用）
#
#   方法 2: OAuth 1.0a（投稿 + 読み取り両方が必要な場合）
#     → 必要なプロジェクト権限: Read and Write
#     → アプリの権限変更後は Access Token を再生成すること
#
# 認証診断: GET /api/debug/x-auth-check（開発環境のみ）

X_API_KEY=""
X_API_SECRET=""
X_ACCESS_TOKEN=""
X_ACCESS_TOKEN_SECRET=""
X_BEARER_TOKEN=""
ENABLE_REAL_X_POSTING="false"

# Instagram API認証情報 (後で追加)
# INSTAGRAM_ACCESS_TOKEN=""
# INSTAGRAM_BUSINESS_ACCOUNT_ID=""

# ─── OpenAI Vision API ───────────────────────────────────────────────────────
# Benchmark AI Auto Tagging 機能で使用 (POST /api/benchmark/vision-tag)
# https://platform.openai.com/api-keys
# 将来 Gemini に差し替える場合は src/lib/visionTagger.ts の createVisionProvider() を変更
OPENAI_API_KEY=""
