# データベースURL (SQLite)
DATABASE_URL="file:./dev.db"

# キャプション生成にClaude APIを使う場合 (任意)
# ANTHROPIC_API_KEY="sk-ant-..."

# ─── X (Twitter) API ─────────────────────────────────────────────────────────
# Developer Portal: https://developer.twitter.com/en/portal/dashboard
# 必要なプロジェクト権限: Read and Write
#
# X_API_KEY             — API Key (Consumer Key)
# X_API_SECRET          — API Secret (Consumer Secret)
# X_ACCESS_TOKEN        — Access Token  (OAuth 1.0a ユーザー認可済み)
# X_ACCESS_TOKEN_SECRET — Access Token Secret
# ENABLE_REAL_X_POSTING — "true" にすると X API v2 で実投稿。それ以外はダミーモード。

X_API_KEY=""
X_API_SECRET=""
X_ACCESS_TOKEN=""
X_ACCESS_TOKEN_SECRET=""
ENABLE_REAL_X_POSTING="false"

# Instagram API認証情報 (後で追加)
# INSTAGRAM_ACCESS_TOKEN=""
# INSTAGRAM_BUSINESS_ACCOUNT_ID=""
